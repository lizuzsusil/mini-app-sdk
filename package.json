{
  "name": "@lizuzsusil/mini-app-sdk",
  "version": "1.0.1",
  "description": "Framework-agnostic Mini App SDK for vendor mini apps. Event-based communication with the host shell.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "browser": "./dist/mini-app-sdk.min.js",
  "unpkg": "./dist/mini-app-sdk.min.js",
  "jsdelivr": "./dist/mini-app-sdk.min.js",
  "exports": {
    ".": {
      "browser": "./dist/mini-app-sdk.min.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "pnpm run build:lib && pnpm run build:cdn",
    "build:lib": "tsup src/index.ts --format cjs,esm --dts --clean",
    "build:cdn": "esbuild src/cdn.ts --bundle --format=iife --platform=browser --target=es2020 --minify --outfile=dist/mini-app-sdk.min.js",
    "build:registry": "esbuild src/cdn.ts --bundle --format=iife --platform=browser --target=es2020 --outfile=dist/mini-app-sdk.registry.global.js",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "prepublishOnly": "pnpm run build",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "esbuild": "^0.27.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
